{
  "name": "htxv2-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol Server для интеграции HTXV2 с GitHub Copilot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc -w"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.10.0",
    "@octokit/rest": "^19.0.13",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "node-fetch": "^2.7.0",
    "redis": "^4.7.1",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0",
    "vscode-languageserver": "^8.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.15",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.2.2"
  }
}
