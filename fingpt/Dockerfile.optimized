FROM nvidia/cuda:12.1.1-base-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Устанавливаем Python и инструменты для сборки
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Создаем виртуальное окружение
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Установка зависимостей
COPY requirements.txt /app/
RUN pip install --upgrade pip && \
    pip install --index-url https://download.pytorch.org/whl/cu121 \
    torch torchvision torchaudio && \
    pip install fastapi uvicorn numpy pydantic

# Второй этап сборки для финального образа
FROM nvidia/cuda:12.1.1-base-ubuntu22.04

LABEL org.opencontainers.image.source="https://github.com/Kaushator/HTXV2" \
      org.opencontainers.image.description="HTXEnterface v2 FinGPT Service" \
      org.opencontainers.image.licenses="MIT" \
      com.docker.scout.analyze=true \
      maintainer="HTX Team"

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Устанавливаем только необходимые runtime зависимости
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Копируем виртуальное окружение из builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Копируем код приложения
COPY server.py /app/server.py

# Создаем пользователя с ограниченными привилегиями
RUN groupadd -r fingpt && useradd -r -g fingpt fingpt && \
    chown -R fingpt:fingpt /app

# Переключаемся на пользователя с ограниченными привилегиями
USER fingpt

# Открываем порт
EXPOSE 8055

# Добавляем проверку работоспособности
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:8055/health || exit 1

# Запускаем приложение
CMD ["python3", "server.py"]
