{
  "name": "HTX Interface v2 Dev",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "dev",
  "workspaceFolder": "/workspace",
  "features": {},
  "forwardPorts": [3000, 8000, 8055, 5432, 6379],
  "shutdownAction": "stopCompose",
  "postCreateCommand": "npm install && (cd frontend && npm ci) && (cd backend && pip install -r requirements.txt)",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}

