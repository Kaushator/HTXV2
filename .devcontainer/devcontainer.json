{
  "name": "HTXV2 ML Development Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [3000, 8000, 8055, 5432, 6379, 8888],
  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Backend API", 
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "notify"
    }
  },
  "shutdownAction": "stopCompose",
  "postCreateCommand": "bash -c 'chmod +x /workspace/.devcontainer/scripts/*.sh && chmod +x /workspace/.devcontainer/scripts/powershell/*.ps1 && /workspace/.devcontainer/scripts/init-dev-container.sh && /workspace/.devcontainer/scripts/setup-mcp-tools.sh'",
  "remoteEnv": {
    "DATABASE_URL": "postgresql+asyncpg://htxv2_user:password@postgres:5432/htxv2",
    "REDIS_URL": "redis://redis:6379/0",
    "ENVIRONMENT": "development",
    "HF_HOME": "/workspace/models/huggingface",
    "TRANSFORMERS_CACHE": "/workspace/models/transformers",
    "TORCH_HOME": "/workspace/models/torch",
    "MLFLOW_TRACKING_URI": "/workspace/models/mlflow",
    "PYTHONPATH": "/workspace"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=/mnt/hdd/models,target=/workspace/models,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort", 
        "ms-python.flake8",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "ms-toolsai.vscode-jupyter-powertoys",
        "ms-python.debugpy",
        "ms-python.pylint",
        "ms-python.autopep8",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-vscode.powershell",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "ms-vscode-remote.remote-containers",
        "redhat.vscode-yaml",
        "hashicorp.terraform"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "powershell": {
            "path": "pwsh",
            "icon": "terminal-powershell"
          },
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          }
        },
        "powershell.powerShellDefaultVersion": "PowerShell Core 7 (x64)",
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "python.linting.enabled": true,
        "python.linting.flake8Enabled": true,
        "python.sortImports.args": ["--profile", "black"],
        "typescript.preferences.includePackageJsonAutoImports": "auto",
        "editor.codeActionsOnSave": {
          "source.organizeImports": true
        }
      }
    }
  }
}
