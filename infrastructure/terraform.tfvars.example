# Copy this file to terraform.tfvars and customize the values

project_id   = "your-gcp-project-id"
project_name = "htxv2"
region       = "us-central1"
zone         = "us-central1-a"
environment  = "dev"

# Database configuration
db_tier       = "db-f1-micro"
database_name = "htxv2"
database_user = "htxv2_user"

# Redis configuration
redis_tier        = "BASIC"
redis_memory_size = 1

# Security
enable_deletion_protection = false

# Monitoring recipients
# alert_emails = ["devops@example.com"]
