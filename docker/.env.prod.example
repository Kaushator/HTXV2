# Production Environment Configuration
# Copy this file to .env.prod and fill in your production values

# Database Configuration
POSTGRES_DB=htxv2_prod
POSTGRES_USER=htxv2_user
POSTGRES_PASSWORD=your_super_secure_postgres_password_here
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws
NEXT_PUBLIC_ENVIRONMENT=production

# ML Service Configuration
ML_PORT=8080
LOCAL_LLM_ENABLED=false
FINGPT_MODEL_PATH=/app/models/fingpt

# External API Keys
OPENAI_API_KEY=your_openai_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here
HTX_API_KEY=your_htx_api_key_here
HTX_SECRET_KEY=your_htx_secret_key_here
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CREDENTIALS_PATH=./credentials
VERTEX_AI_REGION=us-central1
GCS_RAW_BUCKET=your-project-raw-data
GCS_PROCESSED_BUCKET=your-project-processed-data
GCS_ML_MODELS_BUCKET=your-project-ml-models

# Proxy Configuration (if using Nginx)
HTTP_PORT=80
HTTPS_PORT=443

# Monitoring Configuration (optional)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=your_secure_grafana_password

# Container Versions
PYTHON_VERSION=3.11
NODE_VERSION=18

# Scaling Configuration
BACKEND_REPLICAS=2
ML_REPLICAS=1
ETL_REPLICAS=1

# Security
ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com","api.yourdomain.com"]
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem